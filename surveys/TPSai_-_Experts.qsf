ment":"SQ","PrimaryAttribute":"QID100","SecondaryAttribute":"Please select your type of relevant expertise","TertiaryAttribute":null,"Payload":{"QuestionText":"Please select your type of relevant expertise","DefaultChoices":false,"DataExportTag":"Q57","QuestionType":"MC","Selector":"MAVR","SubSelector":"TX","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Please select your type of relevant expertise","Choices":{"1":{"Display":"Expert in the domain of interest (e.g. human-AI interaction, digital mental health)"},"2":{"Display":"Expert in scale development"}},"ChoiceOrder":[1,2],"Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":3,"NextAnswerId":1,"QuestionID":"QID100"}},{"SurveyID":"SV_8oVnVvWYhIxht7E","Element":"SQ","PrimaryAttribute":"QID19","SecondaryAttribute":"I confirm that I am 16 or above.","TertiaryAttribute":null,"Payload":{"QuestionText":"I confirm that I am 16 or above.","DefaultChoices":false,"DataExportTag":"CS_1","QuestionType":"MC","Selector":"SAVR","SubSelector":"TX","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"I confirm that I am 16 or above.","Choices":{"1":{"Display":"Yes"},"2":{"Display":"No"}},"ChoiceOrder":[1,2],"Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":3,"NextAnswerId":1,"QuestionID":"QID19","QuestionText_Unsafe":"I confirm that I have read and understood the Participant Information"}},{"SurveyID":"SV_8oVnVvWYhIxht7E","Element":"SQ","PrimaryAttribute":"QID20","SecondaryAttribute":"I have had the opportunity to think about the participant information displayed in the previous p...","TertiaryAttribute":null,"Payload":{"QuestionText":"I have had the opportunity to think about the participant information displayed in the previous page, ask questions, and understand the answers I have been given.","DefaultChoices":false,"DataExportTag":"CS_3","QuestionType":"MC","Selector":"SAVR","SubSelector":"TX","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"I have had the opportunity to think about the participant information displayed in the previous p...","Choices":{"1":{"Display":"Yes"},"2":{"Display":"No"}},"ChoiceOrder":[1,2],"Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":3,"NextAnswerId":1,"QuestionID":"QID20","QuestionText_Unsafe":"I have had the opportunity to think about the information and ask questions and understand the answers I have been given."}},{"SurveyID":"SV_8oVnVvWYhIxht7E","Element":"SQ","PrimaryAttribute":"QID21","SecondaryAttribute":"I confirm that I agree to the way my data will be collected and processed and that data will be s...","TertiaryAttribute":null,"Payload":{"QuestionText":"I confirm that I agree to the way my data will be collected and processed and that data will be stored for up to 10 years in University archiving facilities in accordance with relevant Data Protection policies and regulations.","DefaultChoices":false,"DataExportTag":"CS_4","QuestionType":"MC","Selector":"SAVR","SubSelector":"TX","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"I confirm that I agree to the way my data will be collected and processed and that data will be s...","Choices":{"1":{"Display":"Yes"},"2":{"Display":"No"}},"ChoiceOrder":[1,2],"Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":3,"NextAnswerId":1,"QuestionID":"QID21","QuestionText_Unsafe":"I confirm that I agree to the way my data will be collected and processed and that data will be stored for up to 10 years in University archiving facilities in accordance with relevant Data Protection policies and regulations."}},{"SurveyID":"SV_8oVnVvWYhIxht7E","Element":"SQ","PrimaryAttribute":"QID22","SecondaryAttribute":"I confirm that I agree that anonymised data might be publicly shared and archived on data sharing...","TertiaryAttribute":null,"Payload":{"QuestionText":"I confirm that I agree that anonymised data might be publicly shared and archived on data sharing platforms.","DefaultChoices":false,"DataExportTag":"CS_5","QuestionType":"MC","Selector":"SAVR","SubSelector":"TX","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"I confirm that I agree that anonymised data might be publicly shared and archived on data sharing...","Choices":{"1":{"Display":"Yes"},"2":{"Display":"No"}},"ChoiceOrder":[1,2],"Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":3,"NextAnswerId":1,"QuestionID":"QID22","QuestionText_Unsafe":"I confirm that I agree that anonymised data might be publicly shared and archived on data sharing platforms."}},{"SurveyID":"SV_8oVnVvWYhIxht7E","Element":"SQ","PrimaryAttribute":"QID23","SecondaryAttribute":"I agree to take part in the study.","TertiaryAttribute":null,"Payload":{"QuestionText":"I agree to take part in the study.","DefaultChoices":false,"DataExportTag":"CS_6","QuestionType":"MC","Selector":"SAVR","SubSelector":"TX","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"I agree to take part in the study.","Choices":{"1":{"Display":"Yes"},"2":{"Display":"No"}},"ChoiceOrder":[1,2],"Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":3,"NextAnswerId":1,"QuestionID":"QID23","QuestionText_Unsafe":"I agree to take part in the study."}},{"SurveyID":"SV_8oVnVvWYhIxht7E","Element":"SQ","PrimaryAttribute":"QID24","SecondaryAttribute":"I confirm that I have read and understood the participant information displayed in the previous p...","TertiaryAttribute":null,"Payload":{"QuestionText":"I confirm that I have read and understood the participant information displayed in the previous page.","DefaultChoices":false,"DataExportTag":"CS_2","QuestionType":"MC","Selector":"SAVR","SubSelector":"TX","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"I confirm that I have read and understood the participant information displayed in the previous p...","Choices":{"1":{"Display":"Yes"},"2":{"Display":"No"}},"ChoiceOrder":[1,2],"Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":3,"NextAnswerId":1,"QuestionID":"QID24"}},{"SurveyID":"SV_8oVnVvWYhIxht7E","Element":"SQ","PrimaryAttribute":"QID3","SecondaryAttribute":"Welcome and thank you for your interest! You are being invited to take part in the expert content...","TertiaryAttribute":null,"Payload":{"QuestionText":"<span style=\"font-size:16px;\">Welcome and thank you for your interest! You are being invited to take part in the expert content evaluation of our planned scale about&nbsp;<em>Trust in Psychological Support from AI (TPSai).<\/em><br>\n<br>\nBefore you decide whether to participate, it is important that you take time to read the following information carefully and understand why the research is being done and what it will involve. If anything is unclear or if you would like more information, ask us using the contact information provided at the bottom of this page.<br>\n<br>\n<span style=\"font-family:&quot;Tms Rmn&quot;,serif\"><b><span style=\"font-family:&quot;Calibri&quot;,sans-serif\">What is the purpose of the study?<\/span><\/b><b> <\/b><span style=\"font-family:&quot;Calibri&quot;,sans-serif\">The purpose of this study is to develop&nbsp;and validate a questionnaire that measures how much people trust generative AIs (like ChatGPT or Claude) for psychological support, such as discussing feelings, sharing worries, or seeking advice about relationships. As part of this process, we are conducting an expert content evaluation to assess whether the items in our scale are clear, relevant, and appropriate.&nbsp;This research is part of a PhD project at the University of Glasgow.<\/span><\/span><br>\n<br>\n<span style=\"font-family:&quot;Tms Rmn&quot;,serif\"><b><span style=\"font-family:&quot;Calibri&quot;,sans-serif\">Why have I been invited to participate? <\/span><\/b><span style=\"font-family:&quot;Calibri&quot;,sans-serif\">You have been invited because of your expertise in a relevant field, such as psychology, human-AI interaction, or psychometric scale development. Your professional judgement will help us assess the content validity of our scale items.<\/span><\/span><br>\n<br>\n<span style=\"font-family:&quot;Tms Rmn&quot;,serif\"><b><span style=\"font-family:&quot;Calibri&quot;,sans-serif\">Do I have to take part?<\/span><\/b><b> <\/b><span style=\"font-family:&quot;Calibri&quot;,sans-serif\">No, participation is voluntary. If you do decide to take part, you will be asked to confirm your consent before starting the survey. You are free to withdraw at any time without giving a reason.<\/span><\/span><br>\n<br><span style=\"font-family:&quot;Tms Rmn&quot;,serif\"><b><span style=\"font-family:&quot;Calibri&quot;,sans-serif\">What will happen to me if I take part?<\/span><\/b><\/span>&nbsp;You will be shown each item from our scale and asked to judge whether it should be kept, dropped, or reworded. If you select 'Reword', you will be able to provide your suggested alternative wording directly in the survey.<br>\n<br>\n<span style=\"font-family:&quot;Tms Rmn&quot;,serif\"><b><span style=\"font-family:&quot;Calibri&quot;,sans-serif\">What do I have to do?&nbsp;<\/span><\/b><span style=\"font-family:&quot;Calibri&quot;,sans-serif\">You simply need to complete the online survey, which you can do at a time and place that is convenient for you.<br>\n<br>\n<strong>What are the possible benefits of taking part?<\/strong> You will receive no direct benefit from taking part in this study. However, your expert input will directly contribute to ensuring the content validity and rigour of a new psychometric scale, which may support future research and the development of more trustworthy AI systems.<\/span><\/span><br>\n<br>\n<span style=\"font-family:&quot;Tms Rmn&quot;,serif\"><b><span style=\"font-family:&quot;Calibri&quot;,sans-serif\">What are the possible disadvantages and risks of taking part? <\/span><\/b><span style=\"font-family:&quot;Calibri&quot;,sans-serif\">The main disadvantage of taking part is the time required to complete the survey. The survey asks you to evaluate items related to trust in AI for psychological support in your capacity as an expert, rather than asking about your personal experiences. We do not anticipate any significant risks from participation. However, if you feel uncomfortable at any point, you are free to pause or withdraw without providing a reason.<\/span><\/span><br>\n<br>\n<span style=\"font-family:&quot;Tms Rmn&quot;,serif\"><b><span style=\"font-family:&quot;Calibri&quot;,sans-serif\">Will my taking part in this study be kept confidential?<\/span><\/b><b> <\/b><span style=\"font-family:&quot;Calibri&quot;,sans-serif\">We do not collect any personally identifiable information such as your name or contact details. You will be identified only by an ID number, and any responses you provide cannot be traced back to you. Survey data will be collected through Qualtrics (a secure university-approved platform).<\/span><\/span><br>\n<br>\n<span style=\"font-family:&quot;Tms Rmn&quot;,serif\"><b><span style=\"font-family:&quot;Calibri&quot;,sans-serif\">What will happen to my data? <\/span><\/b><span style=\"font-family:&quot;Calibri&quot;,sans-serif\">The University of Glasgow is the Data Controller for this study. We will collect and store your survey responses in accordance with the General Data Protection Regulation (2018). Once you submit the completed survey, we will not be able to remove your data as we will have no way to identify which responses are yours.<b> <\/b>The data will be kept for up to 10 years in line with the University of Glasgow's retention policy. After this period, they will be securely destroyed in accordance with standard procedures. The anonymised data may be shared publicly through data sharing platforms. Your name or any identifying information will not appear in any publication or shared dataset.<\/span><\/span><br>\n<br>\n<span style=\"font-family:&quot;Tms Rmn&quot;,serif\"><b><span style=\"font-family:&quot;Calibri&quot;,sans-serif\">What will happen to the results of the research study? <\/span><\/b><span style=\"font-family:&quot;Calibri&quot;,sans-serif\">The results of this expert evaluation will be used to inform item selection and refinement for the final version of the scale. Findings will be published in academic journals, presented at conferences, and form part of a PhD thesis. Your individual responses will not be identifiable in any publication or report. If you would like to receive a summary of the study findings once they are available, please contact the Principal Investigator using the contact details provided at the end of this section.<\/span><\/span><br>\n<br>\n<span style=\"font-family:&quot;Tms Rmn&quot;,serif\"><b><span style=\"font-family:&quot;Calibri&quot;,sans-serif\">Who is organising and funding the research? <\/span><\/b><span style=\"font-family:&quot;Calibri&quot;,sans-serif\">This research is organised by the University of Glasgow and is part of a PhD project within the Social AI Centre for Doctoral Training. The research is funded by UK Research and Innovation (UKRI) through Grant Reference Number EP\/S02266X\/1.<\/span><\/span><br>\n<br>\n<span style=\"font-family:&quot;Tms Rmn&quot;,serif\"><b><span style=\"font-family:&quot;Calibri&quot;,sans-serif\">Who has reviewed the study? <\/span><\/b><span style=\"font-family:&quot;Calibri&quot;,sans-serif\">The project has been reviewed by University of Glasgow College of Medical, Veterinary &amp; Life Sciences Ethics Committee.<\/span><\/span><br>\n<br>\n<span style=\"font-family:&quot;Tms Rmn&quot;,serif\"><b><span style=\"font-family:&quot;Calibri&quot;,sans-serif\">Contact for Further Information<\/span><\/b><\/span><br>\n<span style=\"font-family:&quot;Tms Rmn&quot;,serif\"><i><span style=\"font-family:&quot;Calibri&quot;,sans-serif\">Need information about the study?<\/span><\/i><span style=\"font-family:&quot;Calibri&quot;,sans-serif\">&nbsp;<br>\nRiccardo Volpato (Lead Researcher)<\/span><br>\n<a href=\"mailto:r.volpato.1@research.gla.ac.uk\" style=\"color:#0563c1; text-decoration:underline\"><span style=\"font-family:&quot;Calibri&quot;,sans-serif\">r.volpato.1@research.gla.ac.uk<\/span><\/a><\/span><br>\n<br>\n<span style=\"font-family:&quot;Tms Rmn&quot;,serif\"><i><span style=\"font-family:&quot;Calibri&quot;,sans-serif\">Have concerns about the research?<\/span><\/i><span style=\"font-family:&quot;Calibri&quot;,sans-serif\">&nbsp;<br>\nProfessor Lisa DeBruine (Supervisor)<\/span><br>\n<a href=\"mailto:lisa.debruine@glasgow.ac.uk\" style=\"color:#0563c1; text-decoration:underline\"><span style=\"font-family:&quot;Calibri&quot;,sans-serif\">lisa.debruine@glasgow.ac.uk<\/span><\/a><\/span><br>\n<br>\n<span style=\"font-family:&quot;Tms Rmn&quot;,serif\"><i><span style=\"font-family:&quot;Calibri&quot;,sans-serif\">Questions about your data protection rights?<\/span><\/i>&nbsp;<br>\n<span style=\"font-family:&quot;Calibri&quot;,sans-serif\">Glasgow University Data Protection Officer<\/span><br>\n<a href=\"mailto:dp@gla.ac.uk\" style=\"color:#0563c1; text-decoration:underline\"><span style=\"font-family:&quot;Calibri&quot;,sans-serif\">dp@gla.ac.uk<\/span><\/a><\/span><br>\n<br>\n<span style=\"font-family:&quot;Tms Rmn&quot;,serif\"><i><span style=\"font-family:&quot;Calibri&quot;,sans-serif\">Thank you for taking the time to read this information.<\/span><\/i><\/span><\/span>","DefaultChoices":false,"DataExportTag":"INFO","QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Welcome and thank you for your interest! You are being invited to take part in the expert content...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionID":"QID3","QuestionText_Unsafe":"Welcome and thank you for your interest!&nbsp;<br>\n<br>\nYou are being invited to take part in our research study, titled \u201c<em>Trust in Psychological Support from AI (TPSai)\"&nbsp;<br><br>Our study is about understanding how people trust generative AI for emotional and mental health support<\/em>.<br>\n<br>\nBefore you decide whether to participate, it is important that you take time to read the following information carefully and understand why the research is being done and what it will involve. Ask us if anything is unclear or if you would like more information."}},{"SurveyID":"SV_8oVnVvWYhIxht7E","Element":"SQ","PrimaryAttribute":"QID50","SecondaryAttribute":"The purpose of our research is to develop and validate a questionnaire that measures how much peo...","TertiaryAttribute":null,"Payload":{"QuestionText":"<p>The purpose of our research is to develop and validate a questionnaire that measures how much people trust generative AIs (like ChatGPT or Claude) for psychological support, such as discussing feelings, sharing worries, or seeking advice about relationships. As part of this process, we are conducting an expert content evaluation to assess whether the items in our scale are clear, relevant, and appropriate.<br><\/p><p><br><\/p><p>Over the next three sections, you will review items from three sub-scales: <em>Trust<\/em>, <em>Distrust<\/em>, and <em>Corporate Distrust.<\/em><\/p>\n\n<p><br><\/p><p>For each item, please indicate whether it should be:<\/p>\n\n<ul>\n\t<li><strong>Keep<\/strong> \u2013 retain the item as written<\/li>\n\t<li><strong>Drop<\/strong> \u2013 remove the item from the scale<\/li>\n\t<li><strong>Reword<\/strong> \u2013 revise the item wording (a text box will appear next to this option for your suggested rewording)<\/li>\n<\/ul>\n\n<p><br><\/p><p>Responses to all questions are required.<\/p><p><br><\/p><p>Before the items, please answer the two questions below.<\/p>","DefaultChoices":false,"DataExportTag":"INTRO","QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"The purpose of our research is to develop and validate a questionnaire that measures how much peo...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionID":"QID50","QuestionText_Unsafe":"<p>Thank you for participating in this expert content evaluation of the TPSai scale.<\/p><p>You will review items from three scales: <strong>Trust<\/strong>, <strong>Distrust<\/strong>, and <strong>Corporate Distrust<\/strong>.<\/p><p>For each item, please indicate whether it should be:<\/p><ul><li><strong>Keep<\/strong> &ndash; retain the item as written<\/li><li><strong>Drop<\/strong> &ndash; remove the item from the scale<\/li><li><strong>Reword<\/strong> &ndash; revise the item wording (a text box will appear next to this option for your suggestion)<\/li><\/ul><p>All questions are mandatory.<\/p>"}},{"SurveyID":"SV_8oVnVvWYhIxht7E","Element":"SQ","PrimaryAttribute":"QID51","SecondaryAttribute":"Section 1 of 3: Trust Items Thinking about ${q:\/\/QID97\/ChoiceGroup\/SelectedChoicesTextEntry} (whi...","TertiaryAttribute":null,"Payload":{"QuestionText":"<strong>Section 1 of 3: Trust Items<\/strong><br><br>Thinking about ${q:\/\/QID97\/ChoiceGroup\/SelectedChoicesTextEntry} (which we refer to as \"the AI\"), please evaluate each item from the <em>Trust<\/em>&nbsp;sub-scale.","DefaultChoices":false,"DataExportTag":"TR_HDR","QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Section 1 of 3: Trust Items Thinking about ${q:\/\/QID97\/ChoiceGroup\/SelectedChoicesTextEntry} (whi...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionID":"QID51","QuestionText_Unsafe":"<strong>Section 1 of 3: Trust Items<\/strong><br>Please evaluate each item from the <em>Trust<\/em> scale."}},{"SurveyID":"SV_8oVnVvWYhIxht7E","Element":"SQ","PrimaryAttribute":"QID52","SecondaryAttribute":"The AI is available whenever I need.","TertiaryAttribute":null,"Payload":{"QuestionText":"The AI is available whenever I need.","DefaultChoices":false,"DataExportTag":"TR_1","QuestionType":"MC","Selector":"SAVR","DataVisibility":{"Private":false,"Hidden":false},"QuestionDescription":"The AI is available whenever I need.","Choices":{"1":{"Display":"Keep"},"2":{"Display":"Drop"},"3":{"Display":"Reword","TextEntry":"true"}},"ChoiceOrder":[1,2,3],"Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionID":"QID52","SubSelector":"TX","QuestionText_Unsafe":"The AI is available whenever I need.","Configuration":{"QuestionDescriptionOption":"UseText"}}},{"SurveyID":"SV_8oVnVvWYhIxht7E","Element":"SQ","PrimaryAttribute":"QID53","SecondaryAttribute":"I trust the AI to respond quickly to any request.","TertiaryAttribute":null,"Payload":{"QuestionText":"I trust the AI to respond quickly to any request.","DefaultChoices":false,"DataExportTag":"TR_2","QuestionType":"MC","Selector":"SAVR","DataVisibility":{"Private":false,"Hidden":false},"QuestionDescription":"I trust the AI to respond quickly to any request.","Choices":{"1":{"Display":"Keep"},"2":{"Display":"Drop"},"3":{"Display":"Reword","TextEntry":"true"}},"ChoiceOrder":[1,2,3],"Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionID":"QID53","SubSelector":"TX","QuestionText_Unsafe":"I trust the AI to respond quickly to any request.","Configuration":{"QuestionDescriptionOption":"UseText"}}},{"SurveyID":"SV_8oVnVvWYhIxht7E","Element":"SQ","PrimaryAttribute":"QID54","SecondaryAttribute":"I trust that what the AI tells me is accurate and reliable.","TertiaryAttribute":null,"Payload":{"QuestionText":"I trust that what the AI tells me is accurate and reliable.","DefaultChoices":false,"DataExportTag":"TR_3","QuestionType":"MC","Selector":"SAVR","DataVisibility":{"Private":false,"Hidden":false},"QuestionDescription":"I trust that what the AI tells me is accurate and reliable.","Choices":{"1":{"Display":"Keep"},"2":{"Display":"Drop"},"3":{"Display":"Reword","TextEntry":"true"}},"ChoiceOrder":[1,2,3],"Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionID":"QID54","SubSelector":"TX","QuestionText_Unsafe":"I trust that what the AI tells me is accurate and reliable.","Configuration":{"QuestionDescriptionOption":"UseText"}}},{"SurveyID":"SV_8oVnVvWYhIxht7E","Element":"SQ","PrimaryAttribute":"QID55","SecondaryAttribute":"I trust the AI to provide information that helps me manage my psychological challenges.","TertiaryAttribute":null,"Payload":{"QuestionText":"I trust the AI to provide information that helps me manage my psychological challenges.","DefaultChoices":false,"DataExportTag":"TR_4","QuestionType":"MC","Selector":"SAVR","DataVisibility":{"Private":false,"Hidden":false},"QuestionDescription":"I trust the AI to provide information that helps me manage my psychological challenges.","Choices":{"1":{"Display":"Keep"},"2":{"Display":"Drop"},"3":{"Display":"Reword","TextEntry":"true"}},"ChoiceOrder":[1,2,3],"Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionID":"QID55","SubSelector":"TX","QuestionText_Unsafe":"I trust the AI to provide information that helps me manage my psychological challenges.","Configuration":{"QuestionDescriptionOption":"UseText"}}},{"SurveyID":"SV_8oVnVvWYhIxht7E","Element":"SQ","PrimaryAttribute":"QID56","SecondaryAttribute":"I trust the AI to analyze my issues objectively.","TertiaryAttribute":null,"Payload":{"QuestionText":"I trust the AI to analyze my issues objectively.","DefaultChoices":false,"DataExportTag":"TR_5","QuestionType":"MC","Selector":"SAVR","DataVisibility":{"Private":false,"Hidden":false},"QuestionDescription":"I trust the AI to analyze my issues objectively.","Choices":{"1":{"Display":"Keep"},"2":{"Display":"Drop"},"3":{"Display":"Reword","TextEntry":"true"}},"ChoiceOrder":[1,2,3],"Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionID":"QID56","SubSelector":"TX","QuestionText_Unsafe":"I trust the AI to analyze my issues objectively.","Configuration":{"QuestionDescriptionOption":"UseText"}}},{"SurveyID":"SV_8oVnVvWYhIxht7E","Element":"SQ","PrimaryAttribute":"QID57","SecondaryAttribute":"I trust the AI to easily recognise what I want to know.","TertiaryAttribute":null,"Payload":{"QuestionText":"I trust the AI to easily recognise what I want to know.","DefaultChoices":false,"DataExportTag":"TR_6","QuestionType":"MC","Selector":"SAVR","DataVisibility":{"Private":false,"Hidden":false},"QuestionDescription":"I trust the AI to easily recognise what I want to know.","Choices":{"1":{"Display":"Keep"},"2":{"Display":"Drop"},"3":{"Display":"Reword","TextEntry":"true"}},"ChoiceOrder":[1,2,3],"Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionID":"QID57","SubSelector":"TX","QuestionText_Unsafe":"I trust the AI to easily recognise what I want to know.","Configuration":{"QuestionDescriptionOption":"UseText"}}},{"SurveyID":"SV_8oVnVvWYhIxht7E","Element":"SQ","PrimaryAttribute":"QID58","SecondaryAttribute":"I trust the AI to give me advice that is appropriate and well-tailored to my specific situation.","TertiaryAttribute":null,"Payload":{"QuestionText":"I trust the AI to give me advice that is appropriate and well-tailored to my specific situation.","DefaultChoices":false,"DataExportTag":"TR_7","QuestionType":"MC","Selector":"SAVR","DataVisibility":{"Private":false,"Hidden":false},"QuestionDescription":"I trust the AI to give me advice that is appropriate and well-tailored to my specific situation.","Choices":{"1":{"Display":"Keep"},"2":{"Display":"Drop"},"3":{"Display":"Reword","TextEntry":"true"}},"ChoiceOrder":[1,2,3],"Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionID":"QID58","SubSelector":"TX","QuestionText_Unsafe":"I trust the AI to give me advice that is appropriate and well-tailored to my specific situation.","Configuration":{"QuestionDescriptionOption":"UseText"}}},{"SurveyID":"SV_8oVnVvWYhIxht7E","Element":"SQ","PrimaryAttribute":"QID59","SecondaryAttribute":"I trust the AI to remind me of what I need to do to feel better.","TertiaryAttribute":null,"Payload":{"QuestionText":"I trust the AI to remind me of what I need to do to feel better.","DefaultChoices":false,"DataExportTag":"TR_8","QuestionType":"MC","Selector":"SAVR","DataVisibility":{"Private":false,"Hidden":false},"QuestionDescription":"I trust the AI to remind me of what I need to do to feel better.","Choices":{"1":{"Display":"Keep"},"2":{"Display":"Drop"},"3":{"Display":"Reword","TextEntry":"true"}},"ChoiceOrder":[1,2,3],"Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionID":"QID59","SubSelector":"TX","QuestionText_Unsafe":"I trust the AI to remind me of what I need to do to feel better.","Configuration":{"QuestionDescriptionOption":"UseText"}}},{"SurveyID":"SV_8oVnVvWYhIxht7E","Element":"SQ","PrimaryAttribute":"QID60","SecondaryAttribute":"I am confident I can guide the AI to give responses that meet my needs.","TertiaryAttribute":null,"Payload":{"QuestionText":"I am confident I can guide the AI to give responses that meet my needs.","DefaultChoices":false,"DataExportTag":"TR_9","QuestionType":"MC","Selector":"SAVR","DataVisibility":{"Private":false,"Hidden":false},"QuestionDescription":"I am confident I can guide the AI to give responses that meet my needs.","Choices":{"1":{"Display":"Keep"},"2":{"Display":"Drop"},"3":{"Display":"Reword","TextEntry":"true"}},"ChoiceOrder":[1,2,3],"Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionID":"QID60","SubSelector":"TX","QuestionText_Unsafe":"I am confident I can guide the AI to give responses that meet my needs.","Configuration":{"QuestionDescriptionOption":"UseText"}}},{"SurveyID":"SV_8oVnVvWYhIxht7E","Element":"SQ","PrimaryAttribute":"QID61","SecondaryAttribute":"I trust the AI to reflect the feelings I share in a way that feels accurate.","TertiaryAttribute":null,"Payload":{"QuestionText":"I trust the AI to reflect the feelings I share in a way that feels accurate.","DefaultChoices":false,"DataExportTag":"TR_10","QuestionType":"MC","Selector":"SAVR","DataVisibility":{"Private":false,"Hidden":false},"QuestionDescription":"I trust the AI to reflect the feelings I share in a way that feels accurate.","Choices":{"1":{"Display":"Keep"},"2":{"Display":"Drop"},"3":{"Display":"Reword","TextEntry":"true"}},"ChoiceOrder":[1,2,3],"Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionID":"QID61","SubSelector":"TX","QuestionText_Unsafe":"I trust the AI to reflect the feelings I share in a way that feels accurate.","Configuration":{"QuestionDescriptionOption":"UseText"}}},{"SurveyID":"SV_8oVnVvWYhIxht7E","Element":"SQ","PrimaryAttribute":"QID62","SecondaryAttribute":"I trust the AI to make me feel heard and validated.","TertiaryAttribute":null,"Payload":{"QuestionText":"I trust the AI to make me feel heard and validated.","DefaultChoices":false,"DataExportTag":"TR_11","QuestionType":"MC","Selector":"SAVR","DataVisibility":{"Private":false,"Hidden":false},"QuestionDescription":"I trust the AI to make me feel heard and validated.","Choices":{"1":{"Display":"Keep"},"2":{"Display":"Drop"},"3":{"Display":"Reword","TextEntry":"true"}},"ChoiceOrder":[1,2,3],"Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionID":"QID62","SubSelector":"TX","QuestionText_Unsafe":"I trust the AI to make me feel heard and validated.","Configuration":{"QuestionDescriptionOption":"UseText"}}},{"SurveyID":"SV_8oVnVvWYhIxht7E","Element":"SQ","PrimaryAttribute":"QID63","SecondaryAttribute":"I feel safe opening up to the AI.","TertiaryAttribute":null,"Payload":{"QuestionText":"I feel safe opening up to the AI.","DefaultChoices":false,"DataExportTag":"TR_12","QuestionType":"MC","Selector":"SAVR","DataVisibility":{"Private":false,"Hidden":false},"QuestionDescription":"I feel safe opening up to the AI.","Choices":{"1":{"Display":"Keep"},"2":{"Display":"Drop"},"3":{"Display":"Reword","TextEntry":"true"}},"ChoiceOrder":[1,2,3],"Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionID":"QID63","SubSelector":"TX","QuestionText_Unsafe":"I feel safe opening up to the AI.","Configuration":{"QuestionDescriptionOption":"UseText"}}},{"SurveyID":"SV_8oVnVvWYhIxht7E","Element":"SQ","PrimaryAttribute":"QID64","SecondaryAttribute":"I trust the AI to help me organise and clarify my thoughts about a difficult situation.","TertiaryAttribute":null,"Payload":{"QuestionText":"I trust the AI to help me organise and clarify my thoughts about a difficult situation.","DefaultChoices":false,"DataExportTag":"TR_13","QuestionType":"MC","Selector":"SAVR","DataVisibility":{"Private":false,"Hidden":false},"QuestionDescription":"I trust the AI to help me organise and clarify my thoughts about a difficult situation.","Choices":{"1":{"Display":"Keep"},"2":{"Display":"Drop"},"3":{"Display":"Reword","TextEntry":"true"}},"ChoiceOrder":[1,2,3],"Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionID":"QID64","SubSelector":"TX","QuestionText_Unsafe":"I trust the AI to help me organise and clarify my thoughts about a difficult situation.","Configuration":{"QuestionDescriptionOption":"UseText"}}},{"SurveyID":"SV_8oVnVvWYhIxht7E","Element":"SQ","PrimaryAttribute":"QID65","SecondaryAttribute":"I trust the AI to help me understand the perspective of someone I am having difficulties with.","TertiaryAttribute":null,"Payload":{"QuestionText":"I trust the AI to help me understand the perspective of someone I am having difficulties with.","DefaultChoices":false,"DataExportTag":"TR_14","QuestionType":"MC","Selector":"SAVR","DataVisibility":{"Private":false,"Hidden":false},"QuestionDescription":"I trust the AI to help me understand the perspective of someone I am having difficulties with.","Choices":{"1":{"Display":"Keep"},"2":{"Display":"Drop"},"3":{"Display":"Reword","TextEntry":"true"}},"ChoiceOrder":[1,2,3],"Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionID":"QID65","SubSelector":"TX","QuestionText_Unsafe":"I trust the AI to help me understand the perspective of someone I am having difficulties with.","Configuration":{"QuestionDescriptionOption":"UseText"}}},{"SurveyID":"SV_8oVnVvWYhIxht7E","Element":"SQ","PrimaryAttribute":"QID66","SecondaryAttribute":"I trust the AI to help me gain new insights into my issues.","TertiaryAttribute":null,"Payload":{"QuestionText":"I trust the AI to help me gain new insights into my issues.","DefaultChoices":false,"DataExportTag":"TR_15","QuestionType":"MC","Selector":"SAVR","DataVisibility":{"Private":false,"Hidden":false},"QuestionDescription":"I trust the AI to help me gain new insights into my issues.","Choices":{"1":{"Display":"Keep"},"2":{"Display":"Drop"},"3":{"Display":"Reword","TextEntry":"true"}},"ChoiceOrder":[1,2,3],"Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionID":"QID66","SubSelector":"TX","QuestionText_Unsafe":"I trust the AI to help me gain new insights into my issues.","Configuration":{"QuestionDescriptionOption":"UseText"}}},{"SurveyID":"SV_8oVnVvWYhIxht7E","Element":"SQ","PrimaryAttribute":"QID67","SecondaryAttribute":"I trust the AI to help me see how my feelings and thoughts fit into what people commonly experience.","TertiaryAttribute":null,"Payload":{"QuestionText":"I trust the AI to help me see how my feelings and thoughts fit into what people commonly experience.","DefaultChoices":false,"DataExportTag":"TR_16","QuestionType":"MC","Selector":"SAVR","DataVisibility":{"Private":false,"Hidden":false},"QuestionDescription":"I trust the AI to help me see how my feelings and thoughts fit into what people commonly experience.","Choices":{"1":{"Display":"Keep"},"2":{"Display":"Drop"},"3":{"Display":"Reword","TextEntry":"true"}},"ChoiceOrder":[1,2,3],"Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionID":"QID67","SubSelector":"TX","QuestionText_Unsafe":"I trust the AI to help me see how my feelings and thoughts fit into what people commonly experience.","Configuration":{"QuestionDescriptionOption":"UseText"}}},{"SurveyID":"SV_8oVnVvWYhIxht7E","Element":"SQ","PrimaryAttribute":"QID68","SecondaryAttribute":"I trust that the AI will provide increasingly better psychological support in the future.","TertiaryAttribute":null,"Payload":{"QuestionText":"I trust that the AI will provide increasingly better psychological support in the future.","DefaultChoices":false,"DataExportTag":"TR_17","QuestionType":"MC","Selector":"SAVR","DataVisibility":{"Private":false,"Hidden":false},"QuestionDescription":"I trust that the AI will provide increasingly better psychological support in the future.","Choices":{"1":{"Display":"Keep"},"2":{"Display":"Drop"},"3":{"Display":"Reword","TextEntry":"true"}},"ChoiceOrder":[1,2,3],"Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionID":"QID68","SubSelector":"TX","QuestionText_Unsafe":"I trust that the AI will provide increasingly better psychological support in the future.","Configuration":{"QuestionDescriptionOption":"UseText"}}},{"SurveyID":"SV_8oVnVvWYhIxht7E","Element":"SQ","PrimaryAttribute":"QID69","SecondaryAttribute":"I trust the AI can accurately determine whether my specific experiences indicate a mental health...","TertiaryAttribute":null,"Payload":{"QuestionText":"I trust the AI can accurately determine whether my specific experiences indicate a mental health condition.","DefaultChoices":false,"DataExpo